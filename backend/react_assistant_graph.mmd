---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	agent(agent)
	tools(tools)
	after_tools(after_tools)
	approval_gate(approval_gate)
	execute_mutations(execute_mutations)
	graceful_stop(graceful_stop)
	__end__([<p>__end__</p>]):::last
	__start__ --> agent;
	after_tools -. &nbsp;end_turn&nbsp; .-> __end__;
	after_tools -.-> agent;
	after_tools -.-> graceful_stop;
	agent -.-> __end__;
	agent -.-> approval_gate;
	agent -.-> tools;
	approval_gate -.-> __end__;
	approval_gate -.-> execute_mutations;
	tools --> after_tools;
	execute_mutations --> __end__;
	graceful_stop --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
