# Copy to `.env` locally (never commit secrets). Each variable below will be read via pydantic-settings in `app/config.py`.
#
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#   OAuth 2.0 Web client credentials from Google Cloud Console.
#
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
#   Must match an authorized redirect URI in Google Cloud Console (OAuth Web client).
#
# OAUTH_POST_LOGIN_REDIRECT=http://localhost:5173
#   Where the backend redirects the browser after OAuth. Must match how you open the SPA
#   (same host as the Vite dev server, e.g. localhost not 127.0.0.1, if your redirect URI uses localhost).
#
# SECRET_KEY=
#   Secret for signing session cookies or JWTs (generate a long random string).
#
# DATABASE_URL=
#   SQLAlchemy URL, e.g. sqlite:///./app/db/databases/calendar_assistant.db for local SQLite.
#
# LANGGRAPH_CHECKPOINT_PATH=app/agent/db/langgraph_checkpoints.sqlite
#   LangGraph SqliteSaver file (relative to backend cwd or absolute). Parent dirs are created if missing.
#
# LLM_PROVIDER=openai
#   Which LLM backend to use: openai | anthropic | ollama
#
# LLM_TEMPERATURE=0
#   Sampling temperature for all providers (0 = deterministic).
#
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
#   Used when LLM_PROVIDER=openai.
#
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
#   Used when LLM_PROVIDER=anthropic (Claude).
#
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
#   Used when LLM_PROVIDER=ollama (local Ollama server).
#
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#   Must list every frontend origin (scheme+host+port) that calls the API with credentials.
#
# GOOGLE_HTTP_TIMEOUT_SECONDS=30
# GOOGLE_API_MAX_RETRIES=3
# GOOGLE_API_RETRY_BASE_DELAY_SECONDS=0.5
#   Timeouts and retry/backoff for Calendar and Gmail API calls.
#
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
#   LangSmith API key (https://smith.langchain.com) — enables traces for LangGraph + LLM calls.
# LANGCHAIN_PROJECT=tenex-calendar
#   Project name in LangSmith (optional but recommended).
# LANGCHAIN_ENDPOINT=
#   Only for self-hosted LangSmith; omit for cloud.
